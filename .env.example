SERVICE_HUB_IMAGE=registry.example.com/orchidea/service-hub:latest
SERVICE_HUB_CONTAINER_NAME=service-hub
SERVICE_HUB_BIND_PORT=8080
SERVICE_HUB_DATA_DIR=./data
HOST=0.0.0.0
PORT=8080
ADMIN_TOKEN=replace-with-strong-admin-token
HEARTBEAT_TIMEOUT=90
COMMAND_HISTORY_LIMIT=200
DATABASE_URL=sqlite:////data/service-hub/service-hub.db
# MySQL example:
# DATABASE_URL=mysql+pymysql://root:YOUR_PASSWORD@host.docker.internal:3306/service_hub

# service-platform 环境变量示例
# 复制为 .env 并按部署环境填写;敏感值(密码 / JWT 密钥 / hub token)勿提交。

# --- HTTP 服务 ---
HOST=0.0.0.0
PORT=8080

# --- 平台台账库(机群 MySQL8 独立库 service_platform) ---
# 生产: mysql+pymysql://<user>:<pass>@<host>:<port>/service_platform
# 缺省走本地 sqlite 文件,仅供本机起步;测试由 pytest fixture 注入临时文件库。
DATABASE_URL=sqlite:///./service-platform.db

# --- 单 admin 登录(人类会话,JWT) ---
PLATFORM_ADMIN_USER=admin
PLATFORM_ADMIN_PASSWORD=
# JWT 签名密钥:须 ≥32 字符,否则启动即拒绝(纵深防御)。
PLATFORM_JWT_SECRET=
# JWT 有效期(秒),缺省 8h。
PLATFORM_JWT_TTL=28800

# --- 外部 service-hub(命名空间 provision / rotate) ---
SERVICE_HUB_URL=
# 仅服务端持有,绝不下发浏览器。
HUB_ADMIN_TOKEN=

# --- 插件包存储与分发 ---
PLUGIN_STORAGE_DIR=./data/plugins
# 分发响应 url 前缀:PLUGIN_DOWNLOAD_BASE_URL + 相对 url。
PLUGIN_DOWNLOAD_BASE_URL=

# ================= service-console 单镜像环境变量 =================
# cp .env.example .env 后填写;标「必填」的务必改成强随机值。

# ── 必填:鉴权 ───────────────────────────────────────────
# hub 管理 token(platform 服务端调 hub 也复用它)。强随机,勿留默认/空。
ADMIN_TOKEN=
# 控制台登录账号
PLATFORM_ADMIN_USER=admin
PLATFORM_ADMIN_PASSWORD=
# 会话 JWT 签名密钥(强随机,建议 ≥32 字符)
PLATFORM_JWT_SECRET=

# ── 对外端口 ─────────────────────────────────────────────
HTTP_PORT=80

# ── 数据持久化目录(宿主机侧)────────────────────────────
DATA_DIR=./data

# ── 数据库(缺省容器内 sqlite,落 /data;生产可切外部 MySQL)──────
# HUB_DATABASE_URL=mysql+pymysql://user:pass@mysql-host:3306/service_hub
# PLATFORM_DATABASE_URL=mysql+pymysql://user:pass@mysql-host:3306/service_platform

# ── 插件分发(可选)──────────────────────────────────────
# PLUGIN_STORAGE_DIR=/data/plugins
# PLUGIN_DOWNLOAD_BASE_URL=

# ── 镜像 / 容器名(可选)────────────────────────────────
# SERVICE_CONSOLE_IMAGE=oci.bignof.com/orchidea/service-console:latest
# SERVICE_CONSOLE_CONTAINER_NAME=service-console

# ── hub 调优(可选,直接透传给 hub 进程)──────────────────
# HEARTBEAT_TIMEOUT=90
# ROLLING_SHUTDOWN_TIMEOUT=60
# PLATFORM_ENABLE_DOCS=false

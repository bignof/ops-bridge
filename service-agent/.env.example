SERVICE_AGENT_IMAGE=registry.example.com/orchidea/service-agent:latest
SERVICE_AGENT_CONTAINER_NAME=service-agent
WS_URL=ws://192.168.1.100:8080/ws/agent
AGENT_ID=node-1
AGENT_KEY=your-agent-key
RECONNECT_DELAY=5
HEARTBEAT_INTERVAL=30
HEALTH_HOST=0.0.0.0
HEALTH_PORT=18081
HOST_DOCKER_SOCK=/var/run/docker.sock
MANAGED_PROJECTS_ROOT=/data       # 受管 compose 根目录，所有命令/日志流的 dir 必须 realpath 落在其下

# --- 节点控制安全闸（防自杀 / 防越权 / 供应链 / 优雅停机鉴权）---
# agent 自身 compose 目录：命中它（含子目录）的操作一律拒绝，防 agent 把自己 stop/重部署掉。
# ⚠️ 生产建议必填为 agent 自身 compose 目录；留空则「拒操作 agent 自身 project」自杀防护不生效（启动会 WARNING）。
SELF_PROJECT_DIR=
# 镜像 registry 白名单：逗号分隔，pull/重部署前在 agent 这个不可绕过的执行点校验镜像来源。
# 留空=不限制（放行全部）；非空=强制（匹配语义见 services.compose.is_image_registry_allowed）。
IMAGE_REGISTRY_ALLOWLIST=
# worker /api/k8s/shutdown 鉴权 token（优雅停机用，opt-in）：配了非空值则 agent 调该端点时带 X-Shutdown-Token 头。
# ⚠️ 须与 cnp worker 的 K8S_SHUTDOWN_TOKEN 同名同值，否则优雅停机被 worker 拒（403）；留空=不带头（兼容未鉴权端点）。
K8S_SHUTDOWN_TOKEN=
# agent 自报版本：平台据此对旧 agent 禁用其不支持的操作（滚动升级期兼容）。留空用代码默认 1.0.0。
AGENT_VERSION=1.0.0

# --- Nacos（可选，用于零中断滚动重启时从 Nacos 发现服务实例）---
NACOS_SERVER=                    # Nacos 地址，形如 192.168.0.30:8848；留空则禁用实例发现
NACOS_NAMESPACE=                 # 命名空间 ID，留空=public
NACOS_GROUP=DEFAULT_GROUP        # 分组名
NACOS_CONTEXT_PATH=/nacos        # Nacos 上下文路径
NACOS_USERNAME=                  # 开启鉴权时的用户名；留空=匿名访问
NACOS_PASSWORD=                  # 开启鉴权时的密码

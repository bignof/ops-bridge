# service-console 环境变量示例
# 复制为 .env 并按部署环境填写;敏感值(密码 / JWT 密钥 / admin token)勿提交。
# 变量名与默认值以 app/config.py 为权威来源,改名前先改 config.py。

# --- HTTP 服务 ---
HOST=0.0.0.0
PORT=8080

# --- 平台台账库(机群 MySQL8 独立库 service_platform) ---
# 生产: mysql+pymysql://<user>:<pass>@<host>:<port>/service_platform
# 缺省走本地 sqlite 文件,仅供本机起步;测试由 pytest fixture 注入临时文件库。
DATABASE_URL=sqlite:///./service-console.db

# --- 单 admin 登录(人类会话,JWT) ---
PLATFORM_ADMIN_USER=admin
# 【生产必改】admin 登录密码,缺省空串=无法登录;占位,勿提交真实值。
PLATFORM_ADMIN_PASSWORD=
# 【生产必改】JWT 签名密钥:须 ≥32 字符,否则启动即被拒绝(app/main.py lifespan 纵深防御)。
PLATFORM_JWT_SECRET=
# JWT 有效期(秒),缺省 8h。
PLATFORM_JWT_TTL=28800
# 在线接口文档(/docs /redoc /openapi.json)开关:默认 false(生产安全,三者返回 404)。
# 这些端点不在 /api 前缀下,default-deny 中间件不拦,开着即匿名暴露全 API 面;
# 仅本机调试时设为 true。
PLATFORM_ENABLE_DOCS=false

# --- hub 控制链鉴权(hub 已并入本进程;命名空间 provision / rotate 改进程内直调) ---
# S5:删除了 SERVICE_HUB_URL / HUB_ADMIN_TOKEN —— hub 不再是外部服务,platform→hub 为进程内调用。
# ADMIN_TOKEN 仍是 hub 对外 HTTP 控制端点(/api/agents、/api/commands、agent-WS 等)的鉴权令牌,
# 也是进程内适配器满足 handler 自校验的来源。【生产必改】仅服务端持有,绝不下发浏览器;占位,勿提交真实值。
ADMIN_TOKEN=
# agent 心跳超时(秒)与命令历史上限(可选,缺省即 hub 默认值 90 / 200)。
# HEARTBEAT_TIMEOUT=90
# COMMAND_HISTORY_LIMIT=200

# --- 插件包存储与分发 ---
# 插件包 .tgz 落盘目录;容器部署须挂卷持久化(见 Dockerfile VOLUME 与 README)。
PLUGIN_STORAGE_DIR=./data/plugins
# 分发响应 url 前缀:PLUGIN_DOWNLOAD_BASE_URL + 相对 url(/api/distribution/download/<id>)。
PLUGIN_DOWNLOAD_BASE_URL=

# --- 上传大小上限(可选,由 app/routers/plugin_versions.py 直接读,非 config.py) ---
# 应用层单包字节上限,缺省 200MB;另须配 nginx client_max_body_size,否则大包在边缘即被拦。
# PLUGIN_MAX_UPLOAD_BYTES=209715200

# =============================================================================
# service-platform 部署栈级 .env 示例(自带 nginx + hub + platform 三服务)
# -----------------------------------------------------------------------------
# 复制为 .env 并按部署环境填写。敏感值(密码 / JWT 密钥 / hub token)一律占位,勿提交真值。
#
# ⚠️ 本 .env 同时被 service-hub 与 service-platform 经 `env_file: .env` 加载。两者共享同一份
#    变量表,故同名变量(如 DATABASE_URL)会被双方读到。为避免「两个服务连同一个库」,compose
#    对二者的 DATABASE_URL 分别用 SERVICE_HUB_DATABASE_URL / SERVICE_PLATFORM_DATABASE_URL
#    在 service 级 `environment:` 覆盖(其优先级高于 env_file)。请配下面两个分库变量,而不是
#    直接写一个全局 DATABASE_URL。
# =============================================================================

# --- 镜像名(由部署侧填真实 registry 路径;${...:?} 缺省即报错) ---
SERVICE_HUB_IMAGE=registry.example.com/orchidea/service-hub:latest
SERVICE_PLATFORM_IMAGE=registry.example.com/orchidea/service-platform:latest

# --- 容器名 / 数据目录(可选,留默认即可) ---
# NGINX_CONTAINER_NAME=service-edge-nginx
# SERVICE_HUB_CONTAINER_NAME=service-hub
# SERVICE_PLATFORM_CONTAINER_NAME=service-platform
SERVICE_HUB_DATA_DIR=./data/service-hub
SERVICE_PLATFORM_DATA_DIR=./data/service-platform

# --- service-hub 鉴权 ---
# 【生产必改】hub admin token(只读/日志/命令端点鉴权)。占位,勿提交真值。
ADMIN_TOKEN=replace-with-strong-admin-token
# agent 心跳超时(秒)与命令历史上限,沿用 hub 默认。
HEARTBEAT_TIMEOUT=90
COMMAND_HISTORY_LIMIT=200

# --- service-platform:单 admin 登录(人类会话,JWT) ---
PLATFORM_ADMIN_USER=admin
# 【生产必改】admin 登录密码,缺省空串=无法登录。占位,勿提交真值。
PLATFORM_ADMIN_PASSWORD=
# 【生产必改】JWT 签名密钥:须 ≥32 字符,否则 platform 启动即被拒(app/main.py lifespan)。占位。
PLATFORM_JWT_SECRET=
# JWT 有效期(秒),缺省 8h。
PLATFORM_JWT_TTL=28800
# 在线接口文档开关:生产保持 false(/docs /redoc /openapi.json 返回 404);仅本机调试设 true。
PLATFORM_ENABLE_DOCS=false

# --- service-platform → service-hub(平台服务端经内网调 hub,不经 nginx) ---
# 容器内固定走 svc_internal 内网解析到 hub 服务名;一般不用改。
SERVICE_HUB_URL=http://service-hub:8080
# 【生产必改】platform 持有的 hub admin token:**必须与上面 service-hub 的 ADMIN_TOKEN 完全一致**。
# 仅服务端持有,绝不下发浏览器。占位,勿提交真值。
HUB_ADMIN_TOKEN=replace-with-strong-admin-token

# --- 数据库(分库:hub 与 platform 各自独立库;compose 在 service 级覆盖,优先于 env_file) ---
# 缺省走容器内 sqlite(仅本机起步用)。生产指向机群外部 MySQL8 独立库:
#   - 外部 MySQL 经宿主机回环可达时用 host.docker.internal(compose 已配 extra_hosts)。
#   - 网络是普通 bridge(非 internal),容器可正常出站连外部 MySQL/Redis。
# service-hub 库:
SERVICE_HUB_DATABASE_URL=sqlite:////data/service-hub/service-hub.db
# 生产示例: SERVICE_HUB_DATABASE_URL=mysql+pymysql://<user>:<pass>@host.docker.internal:3306/service_hub
# service-platform 库:
SERVICE_PLATFORM_DATABASE_URL=sqlite:////data/service-platform/service-platform.db
# 生产示例: SERVICE_PLATFORM_DATABASE_URL=mysql+pymysql://<user>:<pass>@host.docker.internal:3306/service_platform

# --- 插件包存储(platform;须挂卷持久化,见 compose volumes) ---
# 容器内路径,落到 SERVICE_PLATFORM_DATA_DIR 挂载卷下;多节点拉包须改为共享存储路径。
PLUGIN_STORAGE_DIR=/data/service-platform/plugins
# 分发响应 url 前缀(PLUGIN_DOWNLOAD_BASE_URL + 相对 url);经 nginx 对外则填边缘域名。
PLUGIN_DOWNLOAD_BASE_URL=
# 单包上传字节上限(可选,缺省 200MB);改这里须同步改 nginx.conf 的 client_max_body_size。
# PLUGIN_MAX_UPLOAD_BYTES=209715200
